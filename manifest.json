{
  "manifest_version": 3,
  "name": "Manga Reader Translator",
  "version": "1.0",
  "description": "Deteta e traduz balões de mangá em tempo real.",
  "permissions": [
    "storage", 
    "unlimitedStorage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "interfaceExtensao.html"
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["storageManager.js", "filtro.js", "content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["avisoManager.js"],
      "matches": ["<all_urls>"]
    }
  ]
}