{
  "manifest_version": 3,
  "name": "Manga Reader Translator",
  "version": "1.0",
  "description": "Leia qualquer mangá no seu idioma! O Manga Reader Translator detecta textos em imagens instantaneamente e sobrepõe a tradução de forma fluida. Compatível com os principais leitores online.",
  "permissions": [
    "storage", 
    "unlimitedStorage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "interfaceExtensao.html"
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "modules/importarModulo.js",
        "storageManager.js", 
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "modules/urlMonitor.js",
        "filtro.js", 
        "avisoManager.js", 
        "modules/eventManager.js", 
        "modules/utils.js"
    ],
      "matches": ["<all_urls>"]
    }
  ]
}